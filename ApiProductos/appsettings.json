{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/api-log-.txt",
          "rollingInterval": "Day",
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "CadenaSQL": "Data Source=.\\SQLEXPRESS;Initial Catalog=Inventario;Integrated Security=True;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Security": {
    "JwtSecret": "2b93d0a15b00ec203f8cd23d566b3a95f0cb649223b7d1152cbab6ae56684221",
    "JwtIssuer": "Inventario",
    "JwtAudience": "Inventario",
    "JwtExpirationHours": 24,
    "AesKey": "63f4945d921d599f27ae4fdf5bada3f1",
    "AesIV": "e7fba06eaeb06b6a"
  }
}
